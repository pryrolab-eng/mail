# ─── Supabase ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# App URL (tracking links, OAuth redirects)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Cron / scheduled jobs (follow-ups, inbox check)
CRON_SECRET=

# Test scripts — Supabase auth user id (same account as dashboard)
TEST_USER_ID=

# ─── Pryro (email generation “your company” block) ─────────────────────────
PRYRO_WEBSITE_URL=https://pryro.com
# NEXT_PUBLIC_PRYRO_WEBSITE_URL=

# ─── Enrichment (free, optional) ───────────────────────────────────────────
# Google Knowledge Graph Search API — no billing required
# https://console.cloud.google.com → Enable "Knowledge Graph Search API" → API key
GOOGLE_KNOWLEDGE_GRAPH_API_KEY=

# ─── Google Maps Docker (gosom) — optional, replaces Puppeteer for Maps ───
# docker run -v gmaps-playwright-cache:/opt -v ./gmapsdata:/gmapsdata -p 8080:8080 \
#   gosom/google-maps-scraper -data-folder /gmapsdata -email
# GMAPS_SCRAPER_URL=http://localhost:8080
# GMAPS_SCRAPER_API_KEY=
# GMAPS_SCRAPER_MAX_DEPTH=5
# GMAPS_SCRAPER_POLL_MS=5000
# GMAPS_SCRAPER_JOB_TIMEOUT_MS=600000

# Docker Maps: CSV vs website email + no-website enrich (defaults: on)
# GMAPS_DOCKER_WEBSITE_EMAIL_VERIFY=true
# GMAPS_DOCKER_WEBSITE_EMAIL_FALLBACK=true
# GMAPS_DOCKER_NO_WEBSITE_ENRICH=true
# GMAPS_DOCKER_AI_EMAIL_PICK=true
# GMAPS_DOCKER_AI_EMAIL_PICK=false

# Read website from Maps place URL when CSV website column is empty (default: on)
# GMAPS_MAPS_LINK_WEBSITE=true

# ─── Website / browser scrape ──────────────────────────────────────────────
# One shared Chrome per scrape job — faster, less RAM (default: on)
# SCRAPE_BROWSER_POOL=true
# SCRAPE_BROWSER_POOL=false

# Retry site crawl in headless Chrome when HTTP finds no email (default: on)
# WEBSITE_FETCH_PUPPETEER=true
# WEBSITE_FETCH_PUPPETEER=false

# ─── Bing / DuckDuckGo (non-Maps sources + enrich) ───────────────────────────
# Retry with Puppeteer when Bing/DDG HTTP is blocked (default: on)
# SEARCH_PUPPETEER_FALLBACK=true

# Force Puppeteer for search: ddg | bing | all
# SEARCH_USE_PUPPETEER=ddg

# Optional paid Brave Search API (not required)
# BRAVE_SEARCH_API_KEY=

# ─── Optional paid Google APIs (not required for free stack) ───────────────
# GOOGLE_API_KEY=
# GOOGLE_CX=
# GOOGLE_PLACES_API_KEY=
